#!/bin/bash

# Pre-commit hook to prevent committing sensitive information
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "đź”Ť Checking for sensitive information..."

# Patterns to check for
PATTERNS=(
    # OAuth and API Keys
    "GOCSPX-"
    "sk_live_"
    "sk_test_"
    "pk_live_"
    "pk_test_"
    "ghp_"
    "ghs_"
    "github_pat_"
    "AIzaSy"
    "Ov23li"
    
    # Common secret patterns
    "api[_-]?key.*=.*['\"][^'\"]{20,}"
    "secret.*=.*['\"][^'\"]{20,}"
    "token.*=.*['\"][^'\"]{20,}"
    "password.*=.*['\"][^'\"]{8,}"
    
    # Database credentials
    "postgres:\/\/[^:]+:[^@]+@"
    "mongodb:\/\/[^:]+:[^@]+@"
    "mysql:\/\/[^:]+:[^@]+@"
    
    # Webhook secrets and API keys
    "whsec_"
    "re_[A-Za-z0-9_]+"
)

# Files to exclude from checking
EXCLUDE_FILES=(
    ".env.example"
    ".env.local.template"
    "*.md"
    ".githooks/pre-commit"
)

# Build exclude pattern for grep
EXCLUDE_PATTERN=""
for file in "${EXCLUDE_FILES[@]}"; do
    EXCLUDE_PATTERN="$EXCLUDE_PATTERN --exclude=$file"
done

# Check staged files
FOUND_SECRETS=0
for pattern in "${PATTERNS[@]}"; do
    # Check if pattern exists in staged files
    if git diff --cached --name-only | xargs -I {} sh -c "git show :\"{}\" 2>/dev/null | grep -qiE '$pattern'" 2>/dev/null; then
        echo -e "${RED}âťŚ Found potential secret matching pattern: $pattern${NC}"
        FOUND_SECRETS=1
        
        # Show which files contain the pattern
        git diff --cached --name-only | while read file; do
            if git show :"$file" 2>/dev/null | grep -qiE "$pattern"; then
                echo -e "${YELLOW}   â†’ File: $file${NC}"
            fi
        done
    fi
done

# Check for .env files
if git diff --cached --name-only | grep -E "^\.env$|^\.env\.local$|^\.env\.production$|^\.env\.development$" > /dev/null; then
    echo -e "${RED}âťŚ Attempting to commit .env file(s)!${NC}"
    echo -e "${YELLOW}   These files should never be committed.${NC}"
    FOUND_SECRETS=1
fi

# Check for files containing 'SECRET' or 'KEY' in their content
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED_FILES" ]; then
    for file in $STAGED_FILES; do
        # Skip binary files and excluded patterns
        if [[ "$file" =~ \.(jpg|jpeg|png|gif|ico|svg|pdf|zip|tar|gz|exe|dll|so|dylib)$ ]]; then
            continue
        fi
        
        # Skip excluded files
        skip_file=false
        for exclude in "${EXCLUDE_FILES[@]}"; do
            if [[ "$file" == $exclude ]] || [[ "$file" == *"$exclude" ]]; then
                skip_file=true
                break
            fi
        done
        
        if [ "$skip_file" = true ]; then
            continue
        fi
        
        # Check file content
        content=$(git show :"$file" 2>/dev/null)
        if echo "$content" | grep -qE "(CLIENT_SECRET|CLIENT_ID.*=.*[a-zA-Z0-9]{20,}|Bearer [a-zA-Z0-9\-._~+/]+=*)" 2>/dev/null; then
            echo -e "${YELLOW}âš ď¸Ź  Warning: File '$file' may contain sensitive information${NC}"
        fi
    done
fi

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${RED}đźš« Commit blocked: Potential secrets detected!${NC}"
    echo ""
    echo "Actions to take:"
    echo "1. Remove sensitive information from your staged files"
    echo "2. Use environment variables instead of hardcoding secrets"
    echo "3. Add sensitive files to .gitignore"
    echo "4. If this is a false positive, you can bypass with: git commit --no-verify"
    echo ""
    echo "For more information, see: docs/SECURITY_CONFIG_GUIDE.md"
    exit 1
fi

echo -e "${GREEN}âś… No secrets detected in staged files${NC}"
exit 0