# She Sharp - Environment Variables Template
# Copy this file to .env.local and fill in the values.
# For Drizzle/database operations, also copy to .env.

# ============================================================
# Authentication
# ============================================================
AUTH_SECRET=***                        # Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=***                    # Same as AUTH_SECRET
AUTH_URL=http://localhost:3000         # Use https://your-domain.com for production
NEXTAUTH_URL=http://localhost:3000    # Same as AUTH_URL

# ============================================================
# Application
# ============================================================
BASE_URL=http://localhost:3000         # Use https://your-domain.com for production

# ============================================================
# Database (Neon PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host-unpooled/dbname?sslmode=require
NEON_PROJECT_ID=your_neon_project_id

# Additional Database URLs (Vercel/Neon will auto-populate these)
# PGDATABASE=neondb
# PGHOST=your-host-pooler.aws.neon.tech
# PGHOST_UNPOOLED=your-host.aws.neon.tech
# PGPASSWORD=your_password
# PGUSER=neondb_owner
# POSTGRES_DATABASE=neondb
# POSTGRES_HOST=your-host-pooler.aws.neon.tech
# POSTGRES_PASSWORD=your_password
# POSTGRES_PRISMA_URL=postgresql://...
# POSTGRES_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...
# POSTGRES_URL_NO_SSL=postgresql://...
# POSTGRES_USER=neondb_owner

# ============================================================
# OAuth Providers
# ============================================================
# GitHub OAuth App (https://github.com/organizations/NZ-SheSharp/settings/applications)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Client (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ============================================================
# Email Service (Resend - https://resend.com/api-keys)
# ============================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="She Sharp <noreply@shesharp.org.nz>"

# ============================================================
# AI Integration
# ============================================================
# OpenAI (chatbot + mentor matching) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key

# ============================================================
# Cloudinary Image Storage (https://console.cloudinary.com/settings/api-keys)
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# Slack Notifications
# ============================================================
# Incoming Webhooks for form submission alerts
SLACK_VOLUNTEER_WEBHOOK_URL=https://hooks.slack.com/services/your/volunteer/webhook
SLACK_CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/your/contact/webhook

# Bot token for Slack API access (optional - for event data extraction)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ============================================================
# Stack Auth (optional)
# ============================================================
# NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
# NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_your_key
# STACK_SECRET_SERVER_KEY=ssk_your_key

# ============================================================
# Stripe Payments (https://dashboard.stripe.com)
# ============================================================
# Mode switch: "test" or "live" (controls which key set to use)
STRIPE_MODE=test

# Test Mode Keys (https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_test_webhook_secret
STRIPE_TEST_ANNUAL_PRICE_ID=price_your_test_annual_price_id

# Live Mode Keys (https://dashboard.stripe.com/apikeys)
STRIPE_LIVE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_webhook_secret
STRIPE_LIVE_ANNUAL_PRICE_ID=price_your_live_annual_price_id
