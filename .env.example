# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.

# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
POSTGRES_URL=postgresql://user:password@localhost:5432/dbname

# Additional Database URLs (Vercel/Neon will auto-populate these)
# DATABASE_URL_UNPOOLED=postgresql://...
# POSTGRES_PRISMA_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...
# POSTGRES_URL_NO_SSL=postgresql://...

# Authentication
AUTH_SECRET=***  # Used for JWT encryption

# Application
BASE_URL=http://localhost:3000

# Email Service (Recommended: Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="She Sharp <noreply@shesharp.org.nz>"

# AI Integration
GOOGLE_GENERATIVE_AI_API_KEY=***

# OAuth Providers (Required for OAuth login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000  # Use https://your-domain.com for production
NEXTAUTH_SECRET=your_nextauth_secret_here  # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000  # Same as NEXTAUTH_URL

# Stripe Mode Switch: "test" or "live" (controls which key set to use)
STRIPE_MODE=test

# Stripe Test Mode Keys (https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your_test_webhook_secret
STRIPE_TEST_ANNUAL_PRICE_ID=price_your_test_annual_price_id

# Stripe Live Mode Keys (https://dashboard.stripe.com/apikeys)
STRIPE_LIVE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your_live_webhook_secret
STRIPE_LIVE_ANNUAL_PRICE_ID=price_your_live_annual_price_id

# Cloudinary Image Storage (Required for photo uploads)
# Get your credentials from https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Slack Notifications (Optional - for application and contact form alerts)
SLACK_VOLUNTEER_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/your/contact/webhook/url