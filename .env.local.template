# ================================================
# SECURE ENVIRONMENT VARIABLES TEMPLATE
# ================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ================================================
# DATABASE
# ================================================
# Primary database connection
DATABASE_URL=postgresql://user:password@localhost:5432/shesharp
POSTGRES_URL=postgresql://user:password@localhost:5432/shesharp

# Additional database configurations (Vercel/Neon auto-populates)
# DATABASE_URL_UNPOOLED=postgresql://user:password@host/db?sslmode=require
# POSTGRES_PRISMA_URL=postgresql://user:password@host/db?connect_timeout=15
# POSTGRES_URL_NON_POOLING=postgresql://user:password@host/db
# POSTGRES_URL_NO_SSL=postgresql://user:password@host/db

# PostgreSQL connection details (auto-populated by Vercel/Neon)
# PGHOST=your-database-host
# PGUSER=your-database-user
# PGDATABASE=your-database-name
# PGPASSWORD=your-database-password

# ================================================
# AUTHENTICATION
# ================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR_NEW_SECRET_HERE
NEXTAUTH_SECRET=YOUR_NEW_SECRET_HERE

# ================================================
# OAUTH PROVIDERS
# ================================================
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ================================================
# NEXTAUTH CONFIGURATION
# ================================================
# Development: http://localhost:3000
# Production: https://she-sharp.vercel.app
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ================================================
# STRIPE PAYMENTS (Optional)
# ================================================
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ================================================
# APPLICATION
# ================================================
BASE_URL=http://localhost:3000

# ================================================
# EMAIL SERVICE (Optional)
# ================================================
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@yourdomain.com

# ================================================
# AI INTEGRATION (Optional)
# ================================================
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_AI_API_KEY

# ================================================
# PLATFORM-SPECIFIC (Auto-generated)
# ================================================
# These are automatically provided by the platform:
# VERCEL_URL=your-app.vercel.app
# VERCEL_OIDC_TOKEN=auto-generated-by-vercel
# BLOB_READ_WRITE_TOKEN=auto-generated-for-blob-storage
# NEON_PROJECT_ID=auto-generated-by-neon

# ================================================
# PUBLIC VARIABLES (Exposed to client)
# ================================================
# NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
# NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_your_key
# STACK_SECRET_SERVER_KEY=ssk_your_server_key