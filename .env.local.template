# ================================================
# SECURE ENVIRONMENT VARIABLES TEMPLATE
# ================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ================================================
# DATABASE
# ================================================
POSTGRES_URL=postgresql://user:password@localhost:5432/shesharp
DATABASE_URL=postgresql://user:password@localhost:5432/shesharp

# ================================================
# AUTHENTICATION
# ================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR_NEW_SECRET_HERE
NEXTAUTH_SECRET=YOUR_NEW_SECRET_HERE

# ================================================
# OAUTH PROVIDERS
# ================================================
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ================================================
# NEXTAUTH CONFIGURATION
# ================================================
# Development: http://localhost:3000
# Production: https://she-sharp.vercel.app
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ================================================
# STRIPE PAYMENTS (Optional)
# ================================================
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ================================================
# APPLICATION
# ================================================
BASE_URL=http://localhost:3000

# ================================================
# EMAIL SERVICE (Optional)
# ================================================
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@yourdomain.com

# ================================================
# AI INTEGRATION (Optional)
# ================================================
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_AI_API_KEY

# ================================================
# VERCEL (Production Only)
# ================================================
# VERCEL_URL=she-sharp.vercel.app